{
  "name": "spectrum-split",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop audio stem separator using AI-powered Demucs technology - no internet required",
  "author": "Magnus Achor",
  "homepage": "https://github.com/magnusAchor/SpectrumSplit.git",
  "repository": {
    "type": "git",
    "url": "https://github.com/magnusAchor/SpectrumSplit.git"
  },
  "keywords": [
    "audio",
    "separation",
    "stem",
    "demucs",
    "electron",
    "desktop",
    "music",
    "ai",
    "machine-learning"
  ],
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "clean": "rm -rf dist release node_modules/.cache",
    "kill-processes": "pkill -f vite || true && pkill -f uvicorn || true && pkill -f 'backend/main.py' || true",
    "dist": "npm run kill-processes && npm run build && electron-builder",
    "dist:mac": "npm run kill-processes && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "dist:win": "npm run kill-processes && npm run build && electron-builder --win",
    "dist:linux": "npm run kill-processes && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^17.0.0",
    "@hookform/resolvers": "^4.1.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@stripe/react-stripe-js": "^3.0.0",
    "@stripe/stripe-js": "^5.2.0",
    "@tanstack/react-query": "^5.84.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "debug": "^4.4.3",
    "electron-log": "^5.4.3",
    "lodash": "^4.17.21",
    "lucide-react": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.171.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "eslint": "^9.19.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.spectrum.split",
    "productName": "SpectrumSplit",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "package.json"
    ],
    "extraResources": [
    {
      "from": "backend",
      "to": "backend"
    }
  ],
    "asar": true,
    "asarUnpack": "backend/**/*",
    "mac": {
      "target": [
        "zip"
      ],
      "identity": null,
      "icon": "assets/icon.icns",
      "category": "public.app-category.music"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
